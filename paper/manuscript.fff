\begin{figure*}[hbt]
\ifnextchar[{\eatarg}{}
[H]

\caption{\label{fig-fwer-pw}Familywise error rate (Panel A), power
(Panel B), and difference between method (Panel C) for adjusted
\emph{p}-values and probability of direction as a function of the number
of tests (\(m\)) and prior \(\Pr(\text{all } \theta=0)\). The
Šidák-adjusted \emph{p}-value curve (pink) declares at least one
discovery when any two-sided one-sample \emph{z}-test satisfies
\(p<0.05\), whereas the adjusted \emph{pd} curve (blue) declares at
least one discovery when any \(pd>0.975\) under the conjugate normal
Bayesian model. Panel C shows the difference (adjusted pd minus
Šidák-adjusted p-value) for FWER (under the global null) and power
(under the global alternative).}

\pandocbounded{\includegraphics[keepaspectratio]{manuscript_files/figure-pdf/fig-fwer-pw-1.pdf}}

